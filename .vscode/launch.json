{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch svoted start",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "sdk/cmd/svoted/main.go",
            "buildFlags": "-tags=halo2,redpallas,debug_tree",
            "dlvFlags": ["--check-go-version=false"],
            "args": [
                "start",
                "--home",
                "${env:HOME}/.svoted"
            ]
        },
        {
            // Note: svoted must already be running with Delve.
            // Example:
            //   dlv exec ./svoted --headless --listen=:2345 --api-version=2 -- start --home ~/.svoted
            "name": "Attach to running svoted process",
            "type": "go",
            "request": "attach",
            "mode": "remote",
            "port": 2345,
            "host": "127.0.0.1",
            "apiVersion": 1,
            "showLog": true
        },
        {
            // Nullifier tools (nf-server, PIR server) now live in the
            // vote-nullifier-pir repo.  Open that repo separately for
            // LLDB launch configs.
            "name": "(see vote-nullifier-pir repo)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "echo",
            "args": ["Nullifier launch configs moved to vote-nullifier-pir repo"]
        }
    ]
}
